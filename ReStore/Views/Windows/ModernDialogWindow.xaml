<ui:FluentWindow x:Class="ReStore.Views.Windows.ModernDialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="ReStore"
    Width="520"
    MinHeight="210"
    SizeToContent="Height"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}">

    <Border Padding="24">
        <Border x:Name="DialogCard"
                Padding="22"
            Background="{ui:ThemeResource ApplicationBackgroundBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
                CornerRadius="12"
            Effect="{x:Null}"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="14"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="IconBadge"
                        Grid.Row="0"
                        Grid.Column="0"
                        Width="46"
                        Height="46"
                        CornerRadius="23"
                        BorderThickness="1"
                        VerticalAlignment="Top"
                        Margin="0,0,14,0">
                    <TextBlock x:Name="IconTextBlock"
                               Text="i"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="TitleTextBlock"
                           Grid.Row="0"
                           Grid.Column="1"
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                <TextBlock x:Name="MessageTextBlock"
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,12,0,0"
                           LineHeight="22"
                           TextWrapping="Wrap"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>

                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,24,0,0">
                    <ui:Button x:Name="TertiaryButton"
                               Visibility="Collapsed"
                               Appearance="Secondary"
                               MinWidth="96"
                               MinHeight="36"
                               Margin="0,0,10,0"
                               Click="DialogButton_Click"/>
                    <ui:Button x:Name="SecondaryButton"
                               Visibility="Collapsed"
                               Appearance="Secondary"
                               MinWidth="96"
                               MinHeight="36"
                               Margin="0,0,10,0"
                               Click="DialogButton_Click"/>
                    <ui:Button x:Name="PrimaryButton"
                               Appearance="Primary"
                               MinWidth="96"
                               MinHeight="36"
                               Click="DialogButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</ui:FluentWindow>